# Supabase Configuration
# Service role key: usata SOLO server-side dalle API routes (mai esposta al browser, niente prefisso NEXT_PUBLIC_).
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here

# Cron (per /api/cron/check-voting-timeouts)
CRON_SECRET=un_valore_segreto_a_tua_scelta
